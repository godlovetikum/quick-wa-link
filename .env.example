# Copy this file to .env and fill in real values.
# Add these variables in your Netlify dashboard too (Site → Environment Variables).

# URL of your deployed Google Apps Script web app
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Shared secret key — must match CONFIG.SECRET in email.gs
CONTACT_SECRET=replace_with_a_strong_secret_key
